# Copy this file to ./env.properties for local development and replace placeholders.
# Do not commit real secrets.
#
# Quick start with Docker (recommended):
#   1. docker compose up -d          — starts PostgreSQL on localhost:5432
#   2. cp env.properties.example env.properties
#   3. Replace APP_JWT_SECRET with a real local secret (min 32 characters)
#   4. ./mvnw spring-boot:run        — starts the backend on localhost:8080
#   5. Open http://localhost:8080/swagger-ui.html

# ==================== SPRING PROFILE ====================
# Activates the dev profile for local development.
# Remove or change this when deploying to non-dev environments.
spring.profiles.active=dev

APP_JWT_SECRET=replace-with-a-local-secret-at-least-32-characters-long
APP_JWT_EXPIRATION=PT8H

# These defaults match the compose.yml service definition.
# Change only if you connect to a different PostgreSQL instance.
DB_URL=jdbc:postgresql://localhost:5432/rentalops
DB_USERNAME=postgres
DB_PASSWORD=postgres

SERVER_PORT=8080
